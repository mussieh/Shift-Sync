// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MANAGER
  STAFF
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
}

enum SwapStatus {
  PENDING
  ACCEPTED
  APPROVED
  REJECTED
  CANCELLED
}

enum ExceptionType {
  UNAVAILABLE
  AVAILABLE
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  password     String
  role         Role
  firstName    String
  lastName     String
  desiredHours Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  certifications         Certification[]
  availabilities         Availability[]
  availabilityExceptions AvailabilityException[]
  shifts                 ShiftAssignment[]
  notifications          Notification[]
  preferences            NotificationPreference?

  swapRequestsFrom     SwapRequest[] @relation("SwapFromUser")
  swapRequestsTo       SwapRequest[] @relation("SwapToUser")
  // FIX: removed the ambiguous unnamed SwapRequest[] relation that caused
  // Prisma to generate a warning. approvedBy is now a named relation.
  swapRequestsApproved SwapRequest[] @relation("SwapApprovedBy")

  dropRequests        DropRequest[] @relation("offeredBy")
  claimedDropRequests DropRequest[] @relation("claimedBy")

  auditLogs        AuditLog[] @relation("performedBy")
  managedLocations Location[] @relation("LocationManagers")
}

model Location {
  id       String @id @default(cuid())
  name     String
  timezone String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  managers       User[]          @relation("LocationManagers")
  certifications Certification[]
  shifts         Shift[]
}

model Skill {
  id   String @id @default(cuid())
  name String @unique

  certifications    Certification[]    @relation("CertificationSkills")
  shiftRequirements ShiftRequirement[]
}

model Certification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  skills Skill[] @relation("CertificationSkills")

  createdAt DateTime @default(now())

  @@unique([userId, locationId])
}

model Availability {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  dayOfWeek Int
  startHour Int
  endHour   Int

  createdAt DateTime @default(now())

  @@unique([userId, dayOfWeek])
  @@index([userId])
}

model AvailabilityException {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  date DateTime

  startTime DateTime?
  endTime   DateTime?

  type ExceptionType

  createdAt DateTime @default(now())

  @@index([userId, date])
}

model Shift {
  id String @id @default(cuid())

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  date      DateTime
  startTime DateTime
  endTime   DateTime
  status    ShiftStatus
  isPremium Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments  ShiftAssignment[]
  requirements ShiftRequirement[]
  swapRequests SwapRequest[]
  dropRequests DropRequest[]

  @@index([locationId, date])
  @@index([startTime, endTime])
}

model ShiftRequirement {
  id String @id @default(cuid())

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id])

  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id])

  quantity Int

  @@unique([shiftId, skillId])
  @@index([skillId])
}

model ShiftAssignment {
  id String @id @default(cuid())

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@unique([shiftId, userId])
  @@index([userId])
  @@index([userId, shiftId])
}

model SwapRequest {
  id String @id @default(cuid())

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id])

  fromUserId String
  fromUser   User   @relation("SwapFromUser", fields: [fromUserId], references: [id])

  toUserId String?
  toUser   User?   @relation("SwapToUser", fields: [toUserId], references: [id])

  status SwapStatus

  // FIX: named relation to resolve Prisma ambiguity on the User side
  approvedById String?
  approvedBy   User?   @relation("SwapApprovedBy", fields: [approvedById], references: [id])

  requestedAt DateTime  @default(now())
  approvedAt  DateTime?

  @@index([shiftId, status])
  @@index([fromUserId])
  // Supports the Staff B "Incoming" tab query efficiently
  @@index([toUserId, status])
}

model DropRequest {
  id String @id @default(cuid())

  shiftId String
  shift   Shift  @relation(fields: [shiftId], references: [id])

  userId    String
  offeredBy User   @relation("offeredBy", fields: [userId], references: [id])

  claimedById String?
  claimedBy   User?   @relation("claimedBy", fields: [claimedById], references: [id])

  expiresAt DateTime
  // NOTE: DropStatus should ideally be its own enum (PENDING/APPROVED/CANCELLED)
  // rather than reusing SwapStatus. Keeping SwapStatus here to avoid a migration
  // during this iteration — track as tech debt.
  status    SwapStatus

  createdAt DateTime @default(now())

  @@index([shiftId, status])
  @@index([expiresAt])
  // Supports getAvailableDrops filter efficiently
  @@index([status, expiresAt])
}

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  message String
  read    Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([userId, read])
}

model NotificationPreference {
  id String @id @default(cuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  emailEnabled Boolean @default(false)
  inAppEnabled Boolean @default(true)
}

model AuditLog {
  id String @id @default(cuid())

  entityType String
  entityId   String

  action String

  before Json?
  after  Json?

  performedById String
  performedBy   User   @relation("performedBy", fields: [performedById], references: [id])

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
